# Copy this file to .env and fill in your values

# Prisma Postgres / Accelerate URL (recommended for Vercel serverless)
# Get a FREE database at: https://console.prisma.io
# Format: prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_KEY
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY_HERE"

# -- OR -- Standard PostgreSQL (Neon, Supabase, etc.)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
